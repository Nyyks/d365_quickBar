{
  "manifest_version": 3,
  "name": "D365 QuickBar",
  "version": "2.1",
  "description": "Pinne häufig genutzte Ribbon-Buttons in Dynamics 365 F&O in eine Sidebar oder einen eigenen Ribbon-Tab.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*.dynamics.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.dynamics.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "d365quickbar@extension",
      "strict_min_version": "128.0"
    }
  }
}
